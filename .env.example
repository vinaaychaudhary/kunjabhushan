# ============================================================
# KUNJ ABHUSHAN BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (MySQL) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=kunj_abhushan

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Twilio (OTP) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Razorpay (Payments) ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=src/uploads

# ── Frontend URL (CORS) ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://kunjabhushan.com

# ── App Settings ─────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
FREE_SHIPPING_THRESHOLD=499
GST_PERCENTAGE=18
CURRENCY=INR

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Email (optional – for future use) ────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# FROM_EMAIL=noreply@kunjabhushan.com

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET_KEY=your_admin_secret_for_first_setup
